#include <stdio.h>

int main() {
    int days, years, months, rem_days;

    printf("Enter total days: ");
    scanf("%d", &days);
    years = days / 365;
    rem_days = days % 365;
    months = rem_days / 30;
    rem_days = rem_days % 30;

    printf("Years = %d\n", years);
    printf("Months = %d\n", months);
    printf("Days = %d\n", rem_days);
    return 0;
}
